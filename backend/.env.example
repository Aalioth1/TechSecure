# Copiar a .env y ajustar valores.
SECRET_KEY=cambiar-por-clave-secreta-larga
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos: por defecto SQLite (sin USE_MYSQL). Para MySQL local:
# USE_MYSQL=true
USE_MYSQL=false
DB_NAME=techsecure
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
